# ============================================================================
# FinAgent - Environment Configuration
# ============================================================================
# Quick start:
#   1. Copy this file:  cp .env.example .env
#   2. Fill in ONE LLM API key below (DeepSeek is recommended for beginners)
#   3. Or run the setup wizard:  python scripts/setup_llm.py
# ============================================================================

# ===== LLM API Keys (you only need ONE) =====

# DeepSeek — Recommended: cheap, great quality, good for Chinese market analysis
# Get your key at: https://platform.deepseek.com/
DEEPSEEK_API_KEY=your_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com

# OpenAI — GPT-4o / GPT-4o-mini
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_api_key_here

# Alibaba Tongyi (DashScope) — qwen-plus, qwen-max
# Get your key at: https://dashscope.aliyun.com/
DASHSCOPE_API_KEY=your_api_key_here

# Local Ollama — free, no API key needed
# Install Ollama: https://ollama.com/
# LLM_PROVIDER=ollama
# DEFAULT_MODEL=qwen2.5:7b
# OLLAMA_BASE_URL=http://localhost:11434/v1

# ===== More LLM Providers (optional) =====

# Google Gemini
# GOOGLE_API_KEY=your_api_key_here

# Anthropic Claude
# ANTHROPIC_API_KEY=your_api_key_here

# OpenRouter — access many models via one API key
# Get your key at: https://openrouter.ai/
# OPENROUTER_API_KEY=your_api_key_here

# SiliconFlow — Chinese provider with many models
# Get your key at: https://www.siliconflow.cn/
# SILICONFLOW_API_KEY=your_api_key_here

# Custom OpenAI-compatible endpoint
# CUSTOM_OPENAI_API_KEY=your_api_key_here
# CUSTOM_OPENAI_BASE_URL=https://your-api-endpoint.com/v1

# ===== Data Sources (optional) =====

# A-share data — default is AKShare (free, no key needed)
DEFAULT_CHINA_DATA_SOURCE=akshare

# Tushare Pro (more professional A-share data)
# Get your token at: https://tushare.pro/
# TUSHARE_TOKEN=your_token_here

# US stock data via FinnHub
# Get your key at: https://finnhub.io/
# FINNHUB_API_KEY=your_api_key_here

# ===== Database (optional, enables full features) =====

# PostgreSQL — recommended for full functionality
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=your_password
# POSTGRES_DATABASE=tradingagents

# Redis — for caching and real-time features
# REDIS_HOST=localhost
# REDIS_PORT=6379

# ===== Basic Settings =====
TRADINGAGENTS_RESULTS_DIR=./results
TRADINGAGENTS_LOG_LEVEL=INFO
